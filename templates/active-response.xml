  <!-- Active Response Module -->
  <active-response>
    <disabled>no</disabled>
    <ca_store>/var/ossec/etc/wpk_root.pem</ca_store>
    <ca_verification>yes</ca_verification>
  </active-response>

  <!-- Block IP on brute force (SSH/RDP) -->
  <active-response>
    <command>firewall-drop</command>
    <location>local</location>
    <rules_id>5763</rules_id>
    <timeout>300</timeout>
  </active-response>

  <!-- Block IP on web attack -->
  <active-response>
    <command>firewall-drop</command>
    <location>local</location>
    <rules_id>31151</rules_id>
    <timeout>300</timeout>
  </active-response>
