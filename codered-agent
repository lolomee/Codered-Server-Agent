    if not IS_WIN:
        sys.stdout.write(f"    {RED}•{RESET} /etc/codered/\n")
        sys.stdout.write(f"    {RED}•{RESET} /usr/local/bin/codered-agent\n")
    else:
        sys.stdout.write(f"    {RED}•{RESET} C:\\Program Files\\CodeRed\\\n")
    sys.stdout.write("\n")
    sys.stdout.flush()

    confirm = input(f"  Type {BOLD}UNINSTALL{RESET} to confirm, or press Enter to cancel: ").strip()
    if confirm != "UNINSTALL":
        print(f"\n{YELLOW}  Cancelled.{RESET}")
        input(f"  Press {BOLD}Enter{RESET} to return...")
        return

    print(f"\n{CYAN}  Stopping agent service...{RESET}")
    svc = get_svc_name()
    if IS_WIN:
        subprocess.run(["sc", "stop", svc], capture_output=True)
    else:
        subprocess.run(["systemctl", "stop", svc], capture_output=True)
    print(f"{GREEN}  ✔ Service stopped.{RESET}")

    print(f"{CYAN}  Removing packages...{RESET}")
    if IS_WIN:
        subprocess.run(
            'wmic product where "name like \'%Wazuh%\'" call uninstall /nointeractive',
            shell=True, capture_output=True
        )
    else:
        for cmd in [
            ["apt-get", "remove", "--purge", "-y", "wazuh-agent"],
            ["dnf",     "remove", "-y", "wazuh-agent"],
            ["yum",     "remove", "-y", "wazuh-agent"],
        ]:
            try:
                r = subprocess.run(cmd, capture_output=True)
                if r.returncode == 0:
                    break
            except FileNotFoundError:
                continue

    print(f"{CYAN}  Removing CodeRed files...{RESET}")
    if IS_WIN:
        shutil.rmtree(r"C:\Program Files\CodeRed", ignore_errors=True)
    else:
        shutil.rmtree("/etc/codered", ignore_errors=True)
        for f in [
            "/usr/local/bin/codered-agent",
            "/etc/apt/sources.list.d/wazuh.list",
            "/usr/share/keyrings/wazuh.gpg",
            "/etc/yum.repos.d/wazuh.repo",
        ]:
            try: os.remove(f)
            except: pass

    print(f"\n{GREEN}{BOLD}  ✔ CodeRed Server Agent has been completely removed.{RESET}\n")
    sys.exit(0)

# ── Direct subcommands ────────────────────────────────────────────────────────
def cmd_enable(module):
    if module not in MODULES:
        print(f"{RED}Unknown module: {module}{RESET}"); sys.exit(1)
    state = load_state()
    if module in state["enabled"]:
        print(f"{YELLOW}{MODULES[module]['label']} already enabled.{RESET}"); return
    state["enabled"].append(module)
    save_state(state)
    if apply_state(state):
        restart_agent()
        print(f"{GREEN}✔ Enabled: {MODULES[module]['label']}{RESET}")

def cmd_disable(module):
    if module not in MODULES:
        print(f"{RED}Unknown module: {module}{RESET}"); sys.exit(1)
    state = load_state()
    if module not in state["enabled"]:
        print(f"{YELLOW}{MODULES[module]['label']} already disabled.{RESET}"); return
    state["enabled"].remove(module)
    save_state(state)
    if apply_state(state):
        restart_agent()
        print(f"{GREEN}✔ Disabled: {MODULES[module]['label']}{RESET}")

# ── Entry point ───────────────────────────────────────────────────────────────
def main():
    if not is_admin():
        print(f"{RED}Please run as Administrator (Windows) or root (Linux).{RESET}")
        sys.exit(1)

    parser = argparse.ArgumentParser(
        prog="codered-agent",
        description="CodeRed Server Agent — run without args for interactive menu"
    )
    sub = parser.add_subparsers(dest="cmd")
    sub.add_parser("scan");      sub.add_parser("setup")
    sub.add_parser("status");    sub.add_parser("settings")
    sub.add_parser("uninstall"); sub.add_parser("restart")
    p_en  = sub.add_parser("enable");  p_en.add_argument("module",  choices=MODULES.keys())
    p_dis = sub.add_parser("disable"); p_dis.add_argument("module", choices=MODULES.keys())

    args = parser.parse_args()

    direct = {
        "scan":      menu_scan,
        "setup":     menu_setup,
        "status":    menu_status,
        "settings":  menu_settings,
        "uninstall": menu_uninstall,
        "restart":   lambda: apply_state(load_state()) and restart_agent(),
    }

    if args.cmd in direct:
        direct[args.cmd](); return
    if args.cmd == "enable":
        cmd_enable(args.module); return
    if args.cmd == "disable":
        cmd_disable(args.module); return

    try:
        show_main_menu()
    except KeyboardInterrupt:
        clear()
        print(f"  {DIM}Goodbye.{RESET}\n")
        sys.exit(0)

if __name__ == "__main__":
    main()
