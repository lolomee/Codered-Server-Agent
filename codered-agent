# ── Dynamic path detection ────────────────────────────────────────────────────
def find_ossec_conf() -> str:
    """Detect ossec.conf path regardless of install location."""
    if IS_WIN:
        candidates = [
            r"C:\Program Files (x86)\ossec-agent\ossec.conf",
            r"C:\Program Files\ossec-agent\ossec.conf",
            r"C:\ossec-agent\ossec.conf",
        ]
        # Try registry first
        try:
            import winreg
            for root in [winreg.HKEY_LOCAL_MACHINE]:
                for key_path in [
                    r"SOFTWARE\WOW6432Node\Ossec",
                    r"SOFTWARE\Ossec",
                    r"SOFTWARE\WOW6432Node\Wazuh",
                    r"SOFTWARE\Wazuh",
                ]:
                    try:
                        key  = winreg.OpenKey(root, key_path)
                        path = winreg.QueryValueEx(key, "InstallLocation")[0]
                        conf = os.path.join(path, "ossec.conf")
                        if os.path.exists(conf):
                            return conf
                    except Exception:
                        continue
        except Exception:
            pass
        # Fallback: try common paths
        for c in candidates:
            if os.path.exists(c):
                return c
        return candidates[0]   # default even if not found yet
    else:
        candidates = [
            "/var/ossec/etc/ossec.conf",
            "/var/wazuh/etc/ossec.conf",
        ]
        for c in candidates:
            if os.path.exists(c):
                return c
        return candidates[0]

