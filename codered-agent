# ── Service name detection ────────────────────────────────────────────────────
_SVC_NAME = None

def get_svc_name() -> str:
    global _SVC_NAME
    if _SVC_NAME:
        return _SVC_NAME
    if IS_WIN:
        for name in ["WazuhSvc", "Wazuh", "wazuh", "OssecSvc"]:
            r = subprocess.run(["sc", "query", name],
                               capture_output=True, text=True)
            if r.returncode == 0:
                _SVC_NAME = name
                return _SVC_NAME
        # Search all services
        r = subprocess.run(["sc", "query", "type=", "all", "state=", "all"],
                           capture_output=True, text=True)
        for line in r.stdout.splitlines():
            if "wazuh" in line.lower() or "ossec" in line.lower():
                if "SERVICE_NAME:" in line:
                    _SVC_NAME = line.split(":")[-1].strip()
                    return _SVC_NAME
        _SVC_NAME = "WazuhSvc"
    else:
        for name in ["wazuh-agent", "ossec"]:
            r = subprocess.run(["systemctl", "is-active", name],
                               capture_output=True, text=True)
            if r.returncode in (0, 3):
                _SVC_NAME = name
                return _SVC_NAME
        _SVC_NAME = "wazuh-agent"
    return _SVC_NAME

# ── State helpers ─────────────────────────────────────────────────────────────
def load_state() -> dict:
    if os.path.exists(STATE_FILE):
        with open(STATE_FILE) as f:
            return json.load(f)
    return {"enabled": list(DEFAULT_ENABLED), "manager_ip": ""}

def save_state(state: dict):
    os.makedirs(os.path.dirname(STATE_FILE), exist_ok=True)
    with open(STATE_FILE, "w") as f:
        json.dump(state, f, indent=2)

# ── Config validation ─────────────────────────────────────────────────────────
def validate_conf(conf_path: str) -> tuple:
    """
    Validate ossec.conf before applying.
    Returns (ok: bool, error: str)
    """
    # 1. XML structure check (both platforms)
    try:
        ET.parse(conf_path)
    except ET.ParseError as e:
        return False, f"XML parse error: {e}"

    # 2. Check for invalid log formats (scan <localfile> blocks)
    valid = VALID_FORMATS_WIN if IS_WIN else VALID_FORMATS_LINUX
    try:
        tree = ET.parse(conf_path)
        root = tree.getroot()
        for lf in root.iter("localfile"):
            fmt_el = lf.find("log_format")
            if fmt_el is not None and fmt_el.text and fmt_el.text.strip() not in valid:
                return False, f"Invalid log_format '{fmt_el.text.strip()}' for this OS"
    except Exception as e:
        return False, str(e)

    # 3. Linux only: wazuh-agentd -t dry-run
    if not IS_WIN:
        for binary in ["/var/ossec/bin/wazuh-agentd", "/var/ossec/bin/ossec-agentd"]:
            if os.path.exists(binary):
                r = subprocess.run([binary, "-t"],
                                   capture_output=True, text=True)
                if r.returncode != 0:
                    err = (r.stderr or r.stdout or "").strip()
                    return False, err
                break

    return True, ""

# ── ossec.conf helpers ────────────────────────────────────────────────────────
def read_conf() -> str:
    if not os.path.exists(AGENT_CONF):
        return ""
    with open(AGENT_CONF, encoding="utf-8", errors="replace") as f:
        return f.read()

def write_conf(content: str) -> bool:
    """Write config to temp, validate, then atomically replace. Returns success."""
    tmp = AGENT_CONF + ".tmp"
    try:
        with open(tmp, "w", encoding="utf-8") as f:
            f.write(content)
        ok, err = validate_conf(tmp)
        if not ok:
            os.remove(tmp)
            print(f"\n{RED}  ✖ Config validation failed — changes NOT applied.{RESET}")
            print(f"  {DIM}{err[:300]}{RESET}\n")
            return False
        shutil.copy2(AGENT_CONF, AGENT_CONF + ".bak")
        shutil.move(tmp, AGENT_CONF)
        return True
    except Exception as e:
        print(f"{RED}  ✖ Failed to write config: {e}{RESET}")
        try: os.remove(tmp)
        except: pass
        return False

def inject_module(mid: str, conf: str) -> str:
    mod  = MODULES[mid]
    tag  = mod["tag"]
    tmpl = os.path.join(TEMPLATES_DIR, mod["template"])
    if tag in conf:
        return conf
    if not os.path.exists(tmpl):
        print(f"{YELLOW}  [warn] Template not found: {tmpl}{RESET}")
        return conf
    with open(tmpl, encoding="utf-8") as f:
        block = f"\n  {tag}\n" + f.read() + f"\n  <!-- END:{mid} -->\n"
    return conf.replace("</ossec_config>", block + "</ossec_config>")

def remove_module(mid: str, conf: str) -> str:
    tag     = MODULES[mid]["tag"]
    end_tag = f"<!-- END:{mid} -->"
    s = conf.find(tag)
    e = conf.find(end_tag)
    if s == -1 or e == -1:
        return conf
    return conf[:s] + conf[e + len(end_tag):]

def apply_state(state: dict) -> bool:
    conf = read_conf()
    if not conf:
        print(f"{YELLOW}  Agent config not found at {AGENT_CONF}{RESET}")
        return False
    for mid in MODULES:
        conf = remove_module(mid, conf)
    for mid in state["enabled"]:
        conf = inject_module(mid, conf)
    return write_conf(conf)

# ── Service control ───────────────────────────────────────────────────────────
def service_status() -> str:
    try:
        if IS_WIN:
            r = subprocess.run(["sc", "query", get_svc_name()],
                               capture_output=True, text=True)
            return "active" if "RUNNING" in r.stdout else "inactive"
        else:
            r = subprocess.run(["systemctl", "is-active", get_svc_name()],
                               capture_output=True, text=True)
            return r.stdout.strip()
    except Exception:
        return "unknown"

def restart_agent():
    svc = get_svc_name()
    print(f"\n{CYAN}  Restarting CodeRed Agent (service: {svc})...{RESET}")
    try:
        if IS_WIN:
            subprocess.run(["sc", "stop",  svc], capture_output=True)
            import time; time.sleep(2)
            r = subprocess.run(["sc", "start", svc], capture_output=True, text=True)
            if r.returncode == 0:
                print(f"{GREEN}  ✔ Agent restarted successfully.{RESET}")
            else:
                print(f"{YELLOW}  ⚠ Start command sent — check Agent Status to confirm.{RESET}")
        else:
            subprocess.run(["systemctl", "restart", svc], check=True)
            print(f"{GREEN}  ✔ Agent restarted successfully.{RESET}")
    except subprocess.CalledProcessError as e:
        print(f"{RED}  ✖ Failed to restart: {e}{RESET}")
        if IS_WIN:
            print(f"{YELLOW}  Try: sc start {svc}{RESET}")
        else:
            print(f"{YELLOW}  Try: systemctl start {svc}{RESET}")

# ── Viewport helpers ──────────────────────────────────────────────────────────
def get_viewport(reserved=10) -> int:
    try:
        rows = os.get_terminal_size().lines
    except Exception:
        rows = 24
    return max(3, rows - reserved)

