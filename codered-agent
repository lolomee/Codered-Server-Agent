# ── State helpers ─────────────────────────────────────────────────────────────
def load_state() -> dict:
    if os.path.exists(STATE_FILE):
        with open(STATE_FILE) as f:
            return json.load(f)
    return {"enabled": list(DEFAULT_ENABLED), "manager_ip": ""}

def save_state(state: dict):
    os.makedirs(os.path.dirname(STATE_FILE), exist_ok=True)
    with open(STATE_FILE, "w") as f:
        json.dump(state, f, indent=2)

# ── ossec.conf helpers ────────────────────────────────────────────────────────
def read_conf() -> str:
    if not os.path.exists(AGENT_CONF):
        return ""
    with open(AGENT_CONF) as f:
        return f.read()

def write_conf(content: str):
    shutil.copy2(AGENT_CONF, AGENT_CONF + ".bak")
    with open(AGENT_CONF, "w") as f:
        f.write(content)

def inject_module(mid: str, conf: str) -> str:
    mod  = MODULES[mid]
    tag  = mod["tag"]
    tmpl = os.path.join(TEMPLATES_DIR, mod["template"])
    if tag in conf or not os.path.exists(tmpl):
        return conf
    with open(tmpl) as f:
        block = f"\n  {tag}\n" + f.read() + f"\n  <!-- END:{mid} -->\n"
    return conf.replace("</ossec_config>", block + "</ossec_config>")

def remove_module(mid: str, conf: str) -> str:
    tag     = MODULES[mid]["tag"]
    end_tag = f"<!-- END:{mid} -->"
    s = conf.find(tag)
    e = conf.find(end_tag)
    if s == -1 or e == -1:
        return conf
    return conf[:s] + conf[e + len(end_tag):]

def apply_state(state: dict):
    conf = read_conf()
    if not conf:
        print(f"{YELLOW}  Agent config not found at {AGENT_CONF}{RESET}")
        return
    for mid in MODULES:
        conf = remove_module(mid, conf)
    for mid in state["enabled"]:
        conf = inject_module(mid, conf)
    write_conf(conf)

# ── Service control ───────────────────────────────────────────────────────────
def service_status() -> str:
    try:
        if sys.platform == "win32":
            r = subprocess.run(["sc", "query", SVC_NAME], capture_output=True, text=True)
            return "active" if "RUNNING" in r.stdout else "inactive"
        else:
            r = subprocess.run(["systemctl", "is-active", SVC_NAME], capture_output=True, text=True)
            return r.stdout.strip()
    except Exception:
        return "unknown"

def restart_agent():
    print(f"\n{CYAN}  Restarting CodeRed Agent (service: {SVC_NAME})...{RESET}")
    try:
        if sys.platform == "win32":
            stop = subprocess.run(["sc", "stop", SVC_NAME],
                                  capture_output=True, text=True)
            import time; time.sleep(2)
            start = subprocess.run(["sc", "start", SVC_NAME],
                                   capture_output=True, text=True)
            if start.returncode == 0:
                print(f"{GREEN}  ✔ Agent restarted successfully.{RESET}")
            else:
                print(f"{YELLOW}  Agent service not running yet — starting...{RESET}")
                subprocess.run(["sc", "start", SVC_NAME], capture_output=True)
                print(f"{GREEN}  ✔ Agent start command sent.{RESET}")
        else:
            subprocess.run(["systemctl", "restart", SVC_NAME], check=True)
            print(f"{GREEN}  ✔ Agent restarted successfully.{RESET}")
    except subprocess.CalledProcessError as e:
        print(f"{RED}  ✖ Failed to restart agent: {e}{RESET}")
        print(f"{YELLOW}  Try manually: sc start {SVC_NAME}{RESET}")

