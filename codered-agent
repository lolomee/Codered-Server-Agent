DEFAULT_ENABLED = ["log-collection", "fim", "inventory", "threat"]

# ── Colours ───────────────────────────────────────────────────────────────────
GREEN  = "\033[92m"
RED    = "\033[91m"
YELLOW = "\033[93m"
CYAN   = "\033[96m"
BOLD   = "\033[1m"
RESET  = "\033[0m"

def banner():
    print(f"""{CYAN}{BOLD}
  ____          _      ____          _
 / ___|___   __| | ___|  _ \\ ___  __| |
| |   / _ \\ / _` |/ _ \\ |_) / _ \\/ _` |
| |__| (_) | (_| |  __/  _ <  __/ (_| |
 \\____\\___/ \\__,_|\\___|_| \\_\\___|\\__,_|

  Server Agent — Management CLI
{RESET}""")

# ── State helpers ─────────────────────────────────────────────────────────────
def load_state() -> dict:
    if os.path.exists(STATE_FILE):
        with open(STATE_FILE) as f:
            return json.load(f)
    return {"enabled": list(DEFAULT_ENABLED)}

def save_state(state: dict):
    os.makedirs(os.path.dirname(STATE_FILE), exist_ok=True)
    with open(STATE_FILE, "w") as f:
        json.dump(state, f, indent=2)

# ── ossec.conf helpers ────────────────────────────────────────────────────────
def read_conf() -> str:
    with open(OSSEC_CONF) as f:
        return f.read()

def write_conf(content: str):
    # backup first
    shutil.copy2(OSSEC_CONF, OSSEC_CONF + ".bak")
    with open(OSSEC_CONF, "w") as f:
        f.write(content)

def inject_module(module_id: str, conf: str) -> str:
    """Insert module XML block before closing </ossec_config>."""
    mod  = MODULES[module_id]
    tag  = mod["tag"]
    tmpl = os.path.join(TEMPLATES_DIR, mod["template"])

    if tag in conf:
        return conf  # already present

    if not os.path.exists(tmpl):
        print(f"{YELLOW}  [warn] Template not found: {tmpl}{RESET}")
        return conf

    with open(tmpl) as f:
        block = f"\n  {tag}\n" + f.read() + f"\n  <!-- END:{module_id} -->\n"

    return conf.replace("</ossec_config>", block + "</ossec_config>")

def remove_module(module_id: str, conf: str) -> str:
    """Strip module XML block from conf."""
    mod       = MODULES[module_id]
    tag       = mod["tag"]
    end_tag   = f"<!-- END:{module_id} -->"
    start_idx = conf.find(tag)
    end_idx   = conf.find(end_tag)

    if start_idx == -1 or end_idx == -1:
        return conf

    return conf[:start_idx] + conf[end_idx + len(end_tag):]

def apply_state(state: dict):
    conf = read_conf()
    # Remove all managed modules first
    for mid in MODULES:
        conf = remove_module(mid, conf)
    # Inject enabled modules
    for mid in state["enabled"]:
        conf = inject_module(mid, conf)
    write_conf(conf)

# ── Service helpers ───────────────────────────────────────────────────────────
def restart_agent():
    print(f"{CYAN}  Restarting CodeRed Agent...{RESET}")
    r = subprocess.run(["systemctl", "restart", "wazuh-agent"],
                       capture_output=True, text=True)
    if r.returncode == 0:
        print(f"{GREEN}  ✔ Agent restarted successfully.{RESET}")
    else:
        print(f"{RED}  ✖ Failed to restart agent: {r.stderr.strip()}{RESET}")

# ── Interactive setup ─────────────────────────────────────────────────────────
def cmd_setup(_args):
    banner()
    state   = load_state()
    enabled = set(state["enabled"])
    keys    = list(MODULES.keys())
    cursor  = 0

    def render():
        os.system("clear")
        banner()
        print(f"{BOLD}  Select modules to enable  {RESET}(↑↓ move · Space toggle · Enter confirm)\n")
        for i, mid in enumerate(keys):
            mod    = MODULES[mid]
            tick   = f"{GREEN}✔{RESET}" if mid in enabled else f"{RED}✖{RESET}"
            arrow  = f"{CYAN}▶{RESET}" if i == cursor else " "
            print(f"  {arrow} [{tick}] {BOLD}{mod['label']}{RESET}")
            print(f"       {mod['desc']}\n")
        print(f"  {YELLOW}──────────────────────────────────────────{RESET}")

    import tty, termios

    def getch():
        fd   = sys.stdin.fileno()
        old  = termios.tcgetattr(fd)
        try:
            tty.setraw(fd)
            return sys.stdin.read(1)
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)

    render()
    while True:
        ch = getch()
        if ch == "\x1b":
            getch()  # [
            arrow = getch()
            if arrow == "A" and cursor > 0:
                cursor -= 1
            elif arrow == "B" and cursor < len(keys) - 1:
                cursor += 1
        elif ch == " ":
            mid = keys[cursor]
            if mid in enabled:
                enabled.discard(mid)
            else:
                enabled.add(mid)
        elif ch in ("\r", "\n"):
            break
        elif ch == "q":
            print("\n  Cancelled.")
            sys.exit(0)
        render()

    print()
    state["enabled"] = list(enabled)
    save_state(state)

    print(f"{CYAN}  Applying configuration...{RESET}")
    apply_state(state)
    restart_agent()

    print(f"\n{GREEN}{BOLD}  Setup complete! Enabled modules:{RESET}")
    for mid in state["enabled"]:
        print(f"    • {MODULES[mid]['label']}")
    print()

# ── Enable ────────────────────────────────────────────────────────────────────
def cmd_enable(args):
    mid = args.module
    if mid not in MODULES:
        print(f"{RED}Unknown module: {mid}{RESET}")
        print("Available:", ", ".join(MODULES.keys()))
        sys.exit(1)

    state = load_state()
    if mid in state["enabled"]:
        print(f"{YELLOW}{MODULES[mid]['label']} is already enabled.{RESET}")
        return

    state["enabled"].append(mid)
    save_state(state)
    apply_state(state)
    print(f"{GREEN}✔ Enabled: {MODULES[mid]['label']}{RESET}")
    restart_agent()

# ── Disable ───────────────────────────────────────────────────────────────────
def cmd_disable(args):
    mid = args.module
    if mid not in MODULES:
        print(f"{RED}Unknown module: {mid}{RESET}")
        print("Available:", ", ".join(MODULES.keys()))
        sys.exit(1)

    state = load_state()
    if mid not in state["enabled"]:
        print(f"{YELLOW}{MODULES[mid]['label']} is already disabled.{RESET}")
        return

    state["enabled"].remove(mid)
    save_state(state)
    apply_state(state)
    print(f"{GREEN}✔ Disabled: {MODULES[mid]['label']}{RESET}")
    restart_agent()

# ── Status ────────────────────────────────────────────────────────────────────
def cmd_status(_args):
    banner()
    state   = load_state()
    enabled = set(state["enabled"])

    print(f"{BOLD}  Module Status{RESET}\n")
    print(f"  {'Module':<25} {'Status':<12} Description")
    print(f"  {'─'*25} {'─'*12} {'─'*40}")
    for mid, mod in MODULES.items():
        status = f"{GREEN}enabled{RESET} " if mid in enabled else f"{RED}disabled{RESET}"
        print(f"  {mod['label']:<25} {status:<20} {mod['desc']}")
    print()

    # Agent service status
    r = subprocess.run(["systemctl", "is-active", "wazuh-agent"],
                       capture_output=True, text=True)
    svc = r.stdout.strip()
    colour = GREEN if svc == "active" else RED
    print(f"  Agent service: {colour}{BOLD}{svc}{RESET}\n")

# ── Restart ───────────────────────────────────────────────────────────────────
def cmd_restart(_args):
    apply_state(load_state())
    restart_agent()

# ── Scan (Log Discovery) ──────────────────────────────────────────────────────
def cmd_scan(_args):
    try:
        import importlib.util, pathlib
        # Try to load codered-discover.py (hyphen in name needs special import)
        discover_path = None
        search_paths = [
            "/etc/codered/codered-discover.py",
            os.path.join(os.path.dirname(os.path.abspath(__file__)), "codered-discover.py"),
        ]
        for p in search_paths:
            if os.path.exists(p):
                discover_path = p
                break

        if not discover_path:
            print(f"{RED}  codered-discover.py not found.{RESET}")
            print(f"  Expected at /etc/codered/codered-discover.py")
            sys.exit(1)

        spec   = importlib.util.spec_from_file_location("codered_discover", discover_path)
        module = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(module)
        module.run_discovery()

    except KeyboardInterrupt:
        print(f"\n\n{YELLOW}  Scan cancelled.{RESET}\n")
        sys.exit(0)

# ── Main ──────────────────────────────────────────────────────────────────────
def main():
    if os.geteuid() != 0:
        print(f"{RED}Please run as root (sudo codered-agent ...){RESET}")
        sys.exit(1)

    parser = argparse.ArgumentParser(
        prog="codered-agent",
        description="CodeRed Server Agent — module management CLI"
    )
    sub = parser.add_subparsers(dest="cmd")

    sub.add_parser("scan",    help="[1] Scan endpoint and recommend logs to monitor")
    sub.add_parser("setup",   help="[2] Interactive module setup wizard")
    sub.add_parser("status",  help="Show enabled/disabled modules and agent status")
    sub.add_parser("restart", help="Apply config and restart agent")

    p_en = sub.add_parser("enable",  help="Enable a module")
    p_en.add_argument("module", choices=MODULES.keys())

    p_dis = sub.add_parser("disable", help="Disable a module")
    p_dis.add_argument("module", choices=MODULES.keys())

    args = parser.parse_args()

    cmds = {
        "scan"   : cmd_scan,
        "setup"  : cmd_setup,
        "enable" : cmd_enable,
        "disable": cmd_disable,
        "status" : cmd_status,
        "restart": cmd_restart,
    }

    if args.cmd in cmds:
        cmds[args.cmd](args)
    else:
        banner()
        print(f"  {BOLD}Commands:{RESET}\n")
        print(f"  {CYAN}sudo codered-agent scan{RESET}              — Scan & recommend logs to monitor")
        print(f"  {CYAN}sudo codered-agent setup{RESET}             — Interactive module setup wizard")
        print(f"  {CYAN}sudo codered-agent status{RESET}            — Show module & agent status")
        print(f"  {CYAN}sudo codered-agent enable <module>{RESET}   — Enable a module")
        print(f"  {CYAN}sudo codered-agent disable <module>{RESET}  — Disable a module")
        print(f"  {CYAN}sudo codered-agent restart{RESET}           — Apply config & restart agent")
        print()

if __name__ == "__main__":
    main()
