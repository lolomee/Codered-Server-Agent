# ── Service name auto-detection ───────────────────────────────────────────────
def detect_service_name() -> str:
    """Auto-detect the agent service name on this system."""
    if sys.platform == "win32":
        candidates = ["WazuhSvc", "Wazuh", "wazuh", "OssecSvc"]
        for name in candidates:
            r = subprocess.run(["sc", "query", name],
                               capture_output=True, text=True)
            if r.returncode == 0:
                return name
        # Fallback: search all services for wazuh
        r = subprocess.run(
            ["sc", "query", "type=", "all", "state=", "all"],
            capture_output=True, text=True
        )
        for line in r.stdout.splitlines():
            if "wazuh" in line.lower() or "ossec" in line.lower():
                parts = line.strip().split()
                if parts:
                    return parts[-1]
        return "WazuhSvc"  # last resort default
    else:
        candidates = ["wazuh-agent", "ossec"]
        for name in candidates:
            r = subprocess.run(["systemctl", "is-active", name],
                               capture_output=True, text=True)
            if r.returncode in (0, 3):  # 0=active, 3=inactive but exists
                return name
        return "wazuh-agent"

SVC_NAME = detect_service_name()

