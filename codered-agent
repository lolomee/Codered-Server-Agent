#!/usr/bin/env python3
"""
CodeRed Server Agent CLI
Manage and configure CodeRed Server Agent modules.
"""

import os
import sys
import shutil
import subprocess
import argparse
import json
from pathlib import Path

# Allow importing codered-discover from same dir or /etc/codered
sys.path.insert(0, "/etc/codered")
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

# ── Paths ────────────────────────────────────────────────────────────────────
OSSEC_CONF       = "/var/ossec/etc/ossec.conf"
MODULES_DIR      = "/etc/codered/modules"
STATE_FILE       = "/etc/codered/state.json"
