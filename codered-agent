    ("uninstall", "Uninstall Agent",      "Remove CodeRed Server Agent from this system"),
    ("exit",      "Exit",                 ""),
]

def show_main_menu():
    cursor = 0
    while True:
        banner("Management Console")
        svc = service_status()
        svc_col = GREEN if svc == "active" else RED
        print(f"  Agent Service : {svc_col}{BOLD}{svc}{RESET}\n")
        print(f"  {DIM}↑↓ move · Enter select · 1-5 shortcut{RESET}\n")

        for i, (key, label, desc) in enumerate(MENU_ITEMS):
            arrow = f"{CYAN}▶{RESET}" if i == cursor else " "
            num   = f"{DIM}[0]{RESET}" if key == "exit" else f"{CYAN}[{i+1}]{RESET}"
            hi    = BOLD if i == cursor else ""
            print(f"  {arrow} {num} {hi}{label}{RESET}")
            if desc and i == cursor:
                print(f"       {DIM}{desc}{RESET}")
            print()

        ch = getch()
        if   ch == "UP"   and cursor > 0:                  cursor -= 1
        elif ch == "DOWN" and cursor < len(MENU_ITEMS) - 1: cursor += 1
        elif ch in ("\r", "\n"):
            key = MENU_ITEMS[cursor][0]
            if   key == "exit":      clear(); print(f"  {DIM}Goodbye.{RESET}\n"); sys.exit(0)
            elif key == "scan":      menu_scan()
            elif key == "setup":     menu_setup()
            elif key == "status":    menu_status()
            elif key == "settings":  menu_settings()
            elif key == "uninstall": menu_uninstall()
        elif ch == "1": menu_scan()
        elif ch == "2": menu_setup()
        elif ch == "3": menu_status()
        elif ch == "4": menu_settings()
        elif ch == "5": menu_uninstall()
        elif ch == "0": clear(); print(f"  {DIM}Goodbye.{RESET}\n"); sys.exit(0)
        elif ch == "q": clear(); sys.exit(0)

# ─────────────────────────────────────────────────────────────────────────────
# ── 1. SCAN ───────────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
def menu_scan():
    try:
        if not os.path.exists(DISCOVER_PATH):
            banner("Scan Log Directories")
            print(f"{RED}  codered-discover.py not found at:\n  {DISCOVER_PATH}{RESET}\n")
            input("  Press Enter to return...")
            return
        spec   = importlib.util.spec_from_file_location("codered_discover", DISCOVER_PATH)
        module = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(module)
        module.run_discovery()
        input(f"\n  Press {BOLD}Enter{RESET} to return to menu...")
    except KeyboardInterrupt:
        print(f"\n{YELLOW}  Scan cancelled.{RESET}")

# ─────────────────────────────────────────────────────────────────────────────
# ── 2. MODULE SETUP ───────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
def menu_setup():
    state   = load_state()
    enabled = set(state["enabled"])
    keys    = list(MODULES.keys())
    cursor  = 0

    def render():
        banner("Module Setup")
        print(f"  {DIM}↑↓ move · Space toggle · A all · N none · Enter save · Q back{RESET}\n")
        for i, mid in enumerate(keys):
            mod   = MODULES[mid]
            tick  = f"{GREEN}✔{RESET}" if mid in enabled else f"{RED}✖{RESET}"
            arrow = f"{CYAN}▶{RESET}" if i == cursor else " "
            hi    = BOLD if i == cursor else ""
            print(f"  {arrow} [{tick}] {hi}{mod['label']}{RESET}")
            if i == cursor:
                print(f"       {DIM}{mod['desc']}{RESET}")
            print()
        print(f"  {DIM}──────────────────────────────────────{RESET}")
        print(f"  {len(enabled)} module(s) enabled\n")

    render()
    while True:
        ch = getch()
        if   ch == "UP"   and cursor > 0:            cursor -= 1
        elif ch == "DOWN" and cursor < len(keys) - 1: cursor += 1
        elif ch == " ":
            mid = keys[cursor]
            if mid in enabled: enabled.discard(mid)
            else:              enabled.add(mid)
        elif ch.lower() == "a": enabled = set(keys)
        elif ch.lower() == "n": enabled = set()
        elif ch in ("\r", "\n"):
            state["enabled"] = list(enabled)
            save_state(state)
            print(f"\n{CYAN}  Applying configuration...{RESET}")
            apply_state(state)
            restart_agent()
            print(f"\n{GREEN}  ✔ Module configuration saved.{RESET}")
            input(f"\n  Press {BOLD}Enter{RESET} to return to menu...")
            return
        elif ch.lower() == "q":
            return
        render()

