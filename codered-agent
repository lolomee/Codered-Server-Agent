# ── 4. SETTINGS ───────────────────────────────────────────────────────────────
def menu_settings():
    while True:
        banner("Agent Settings")
        state = load_state()
        sys.stdout.write(f"  Manager IP  : {CYAN}{state.get('manager_ip','(not set)')}{RESET}\n")
        sys.stdout.write(f"  Config File : {DIM}{AGENT_CONF}{RESET}\n")
        sys.stdout.write(f"  Templates   : {DIM}{TEMPLATES_DIR}{RESET}\n\n")
        sys.stdout.write(f"  {CYAN}[1]{RESET} Change Manager IP\n")
        sys.stdout.write(f"  {CYAN}[2]{RESET} Test connection to Manager\n")
        sys.stdout.write(f"  {CYAN}[3]{RESET} Restart Agent\n")
        sys.stdout.write(f"  {DIM}[0]{RESET} Back\n\n")
        sys.stdout.flush()

        ch = input("  Select: ").strip()

        if ch == "1":
            new_ip = input(f"\n  Enter new Manager IP or hostname: ").strip()
            if new_ip:
                state["manager_ip"] = new_ip
                save_state(state)
                conf = read_conf()
                if conf:
                    conf = re.sub(r'<address>.*?</address>',
                                  f'<address>{new_ip}</address>', conf)
                    if write_conf(conf):
                        print(f"\n{GREEN}  ✔ Manager IP updated to: {new_ip}{RESET}")
                        restart_agent()
                    else:
                        print(f"{YELLOW}  Manager IP saved to state but config update failed.{RESET}")
            input(f"\n  Press {BOLD}Enter{RESET} to continue...")

        elif ch == "2":
            ip = state.get("manager_ip", "")
            if not ip:
                print(f"\n{RED}  No Manager IP set. Choose option 1 first.{RESET}")
            else:
                print(f"\n  Testing connection to {CYAN}{ip}:1514{RESET}...")
                try:
                    import socket
                    s = socket.create_connection((ip, 1514), timeout=5)
                    s.close()
                    print(f"{GREEN}  ✔ Manager is reachable.{RESET}")
                except Exception as e:
                    print(f"{RED}  ✖ Cannot reach Manager: {e}{RESET}")
                    print(f"{YELLOW}  Check firewall — TCP 1514 must be open.{RESET}")
            input(f"\n  Press {BOLD}Enter{RESET} to continue...")

        elif ch == "3":
            if apply_state(load_state()):
                restart_agent()
            input(f"\n  Press {BOLD}Enter{RESET} to continue...")

        elif ch == "0":
            return

