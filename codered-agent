# ── 3. STATUS ─────────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
def menu_status():
    banner("Agent Status")
    state   = load_state()
    enabled = set(state["enabled"])
    svc     = service_status()
    svc_col = GREEN if svc == "active" else RED

    print(f"  Service Status : {svc_col}{BOLD}{svc}{RESET}")
    print(f"  Manager IP     : {CYAN}{state.get('manager_ip','(not set)')}{RESET}")
    print(f"  Config File    : {DIM}{AGENT_CONF}{RESET}\n")

    print(f"  {BOLD}{'Module':<30} {'Status'}{RESET}")
    print(f"  {'─'*30} {'─'*12}")
    for mid, mod in MODULES.items():
        status = f"{GREEN}enabled{RESET}" if mid in enabled else f"{RED}disabled{RESET}"
        print(f"  {mod['label']:<30} {status}")

    print()
    input(f"  Press {BOLD}Enter{RESET} to return to menu...")

# ─────────────────────────────────────────────────────────────────────────────
# ── 4. SETTINGS ───────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
def menu_settings():
    while True:
        banner("Agent Settings")
        state = load_state()
        print(f"  Manager IP  : {CYAN}{state.get('manager_ip','(not set)')}{RESET}")
        print(f"  Config File : {DIM}{AGENT_CONF}{RESET}\n")
        print(f"  {CYAN}[1]{RESET} Change Manager IP")
        print(f"  {CYAN}[2]{RESET} Test connection to Manager")
        print(f"  {CYAN}[3]{RESET} Restart Agent")
        print(f"  {DIM}[0]{RESET} Back\n")

        ch = input("  Select: ").strip()

        if ch == "1":
            new_ip = input(f"\n  Enter new Manager IP or hostname: ").strip()
            if new_ip:
                state["manager_ip"] = new_ip
                save_state(state)
                conf = read_conf()
                if conf:
                    import re
                    conf = re.sub(r'<address>.*?</address>',
                                  f'<address>{new_ip}</address>', conf)
                    write_conf(conf)
                print(f"\n{GREEN}  ✔ Manager IP updated to: {new_ip}{RESET}")
                restart_agent()
            input(f"\n  Press {BOLD}Enter{RESET} to continue...")

        elif ch == "2":
            ip = state.get("manager_ip", "")
            if not ip:
                print(f"\n{RED}  No Manager IP set. Choose option 1 first.{RESET}")
            else:
                print(f"\n  Testing connection to {CYAN}{ip}:1514{RESET}...")
                try:
                    import socket
                    s = socket.create_connection((ip, 1514), timeout=5)
                    s.close()
                    print(f"{GREEN}  ✔ Manager is reachable.{RESET}")
                except Exception as e:
                    print(f"{RED}  ✖ Cannot reach Manager: {e}{RESET}")
                    print(f"{YELLOW}  Check firewall — TCP 1514 must be open.{RESET}")
            input(f"\n  Press {BOLD}Enter{RESET} to continue...")

        elif ch == "3":
            apply_state(load_state())
            restart_agent()
            input(f"\n  Press {BOLD}Enter{RESET} to continue...")

        elif ch == "0":
            return

# ─────────────────────────────────────────────────────────────────────────────
# ── 5. UNINSTALL ──────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
def menu_uninstall():
    banner("Uninstall Agent")
    print(f"  {YELLOW}{BOLD}Warning: This will remove CodeRed Server Agent from this system.{RESET}")
    print(f"  {YELLOW}All agent configuration and state will be deleted.{RESET}\n")
    print(f"  Items to be removed:")
    print(f"    {RED}•{RESET} Agent service and binaries")
    print(f"    {RED}•{RESET} {AGENT_CONF}")
    if sys.platform != "win32":
        print(f"    {RED}•{RESET} /etc/codered/")
        print(f"    {RED}•{RESET} /usr/local/bin/codered-agent")
    else:
        print(f"    {RED}•{RESET} C:\\Program Files\\CodeRed\\")
    print()

    confirm = input(f"  Type {BOLD}UNINSTALL{RESET} to confirm, or press Enter to cancel: ").strip()
    if confirm != "UNINSTALL":
        print(f"\n{YELLOW}  Cancelled.{RESET}")
        input(f"  Press {BOLD}Enter{RESET} to return...")
        return

    print(f"\n{CYAN}  Stopping agent service...{RESET}")
    try:
        if sys.platform == "win32":
            subprocess.run(["sc", "stop", SVC_NAME], capture_output=True)
        else:
            subprocess.run(["systemctl", "stop", SVC_NAME], capture_output=True)
        print(f"{GREEN}  ✔ Service stopped.{RESET}")
    except Exception:
        print(f"{YELLOW}  Service was not running.{RESET}")

    print(f"{CYAN}  Removing packages...{RESET}")
    if sys.platform == "win32":
        subprocess.run(
            'wmic product where "name like \'%Wazuh%\'" call uninstall /nointeractive',
            shell=True, capture_output=True
        )
    else:
        for cmd in [
            ["apt-get", "remove", "--purge", "-y", "wazuh-agent"],
            ["yum", "remove", "-y", "wazuh-agent"],
        ]:
            try:
                r = subprocess.run(cmd, capture_output=True)
                if r.returncode == 0:
                    break
            except Exception:
                continue

    print(f"{CYAN}  Removing CodeRed files...{RESET}")
    if sys.platform != "win32":
        shutil.rmtree("/etc/codered", ignore_errors=True)
        for f in ["/usr/local/bin/codered-agent",
                  "/etc/apt/sources.list.d/wazuh.list",
                  "/usr/share/keyrings/wazuh.gpg",
                  "/etc/yum.repos.d/wazuh.repo"]:
            try: os.remove(f)
            except: pass
    else:
        shutil.rmtree(r"C:\Program Files\CodeRed", ignore_errors=True)

    print(f"\n{GREEN}{BOLD}  ✔ CodeRed Server Agent has been completely removed.{RESET}\n")
    sys.exit(0)

# ─────────────────────────────────────────────────────────────────────────────
# ── DIRECT SUBCOMMANDS ────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
def cmd_enable(module):
    if module not in MODULES:
        print(f"{RED}Unknown module: {module}{RESET}"); sys.exit(1)
    state = load_state()
    if module in state["enabled"]:
        print(f"{YELLOW}{MODULES[module]['label']} already enabled.{RESET}"); return
    state["enabled"].append(module)
    save_state(state); apply_state(state); restart_agent()
    print(f"{GREEN}✔ Enabled: {MODULES[module]['label']}{RESET}")

def cmd_disable(module):
    if module not in MODULES:
        print(f"{RED}Unknown module: {module}{RESET}"); sys.exit(1)
    state = load_state()
    if module not in state["enabled"]:
        print(f"{YELLOW}{MODULES[module]['label']} already disabled.{RESET}"); return
    state["enabled"].remove(module)
    save_state(state); apply_state(state); restart_agent()
    print(f"{GREEN}✔ Disabled: {MODULES[module]['label']}{RESET}")

# ─────────────────────────────────────────────────────────────────────────────
# ── ENTRY POINT ───────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
def main():
    if not is_admin():
        print(f"{RED}Please run as Administrator (Windows) or root (Linux).{RESET}")
        sys.exit(1)

    parser = argparse.ArgumentParser(
        prog="codered-agent",
        description="CodeRed Server Agent — Management CLI (run without args for interactive menu)"
    )
    sub = parser.add_subparsers(dest="cmd")
    sub.add_parser("scan",      help="Scan log directories")
    sub.add_parser("setup",     help="Module setup wizard")
    sub.add_parser("status",    help="Show agent status")
    sub.add_parser("settings",  help="Configure agent settings")
    sub.add_parser("uninstall", help="Remove agent from this system")
    sub.add_parser("restart",   help="Restart agent service")
    p_en  = sub.add_parser("enable",  help="Enable a module")
    p_en.add_argument("module", choices=MODULES.keys())
    p_dis = sub.add_parser("disable", help="Disable a module")
    p_dis.add_argument("module", choices=MODULES.keys())

    args = parser.parse_args()

    dispatch = {
        "scan":      menu_scan,
        "setup":     menu_setup,
        "status":    menu_status,
        "settings":  menu_settings,
        "uninstall": menu_uninstall,
        "restart":   lambda: (apply_state(load_state()), restart_agent()),
    }

    if args.cmd in dispatch:
        dispatch[args.cmd]()
        return
    if args.cmd == "enable":
        cmd_enable(args.module); return
    if args.cmd == "disable":
        cmd_disable(args.module); return

    # No args → interactive main menu
    try:
        show_main_menu()
    except KeyboardInterrupt:
        clear()
        print(f"  {DIM}Goodbye.{RESET}\n")
        sys.exit(0)

if __name__ == "__main__":
    main()
