def show_main_menu():
    cursor = 0
    while True:
        banner("Management Console")
        svc = service_status()
        svc_col = GREEN if svc == "active" else RED
        sys.stdout.write(f"  Agent Service : {svc_col}{BOLD}{svc}{RESET}\n")
        sys.stdout.write(f"  Config        : {DIM}{AGENT_CONF}{RESET}\n\n")
        sys.stdout.write(f"  {DIM}↑↓ move · Enter select · 1-5 shortcut{RESET}\n\n")

        for i, (key, label, desc) in enumerate(MENU_ITEMS):
            arrow = f"{CYAN}▶{RESET}" if i == cursor else " "
            num   = f"{DIM}[0]{RESET}" if key == "exit" else f"{CYAN}[{i+1}]{RESET}"
            hi    = BOLD if i == cursor else ""
            sys.stdout.write(f"  {arrow} {num} {hi}{label}{RESET}\n")
            if desc and i == cursor:
                sys.stdout.write(f"       {DIM}{desc}{RESET}\n")
            sys.stdout.write("\n")
        sys.stdout.flush()

        ch = getch()
        if   ch == "UP"   and cursor > 0:                   cursor -= 1
        elif ch == "DOWN" and cursor < len(MENU_ITEMS) - 1: cursor += 1
        elif ch in ("\r", "\n"):
            key = MENU_ITEMS[cursor][0]
            if   key == "exit":      clear(); sys.exit(0)
            elif key == "scan":      menu_scan()
            elif key == "setup":     menu_setup()
            elif key == "status":    menu_status()
            elif key == "settings":  menu_settings()
            elif key == "uninstall": menu_uninstall()
        elif ch == "1": menu_scan()
        elif ch == "2": menu_setup()
        elif ch == "3": menu_status()
        elif ch == "4": menu_settings()
        elif ch == "5": menu_uninstall()
        elif ch in ("0", "q"): clear(); sys.exit(0)

# ── 1. SCAN ───────────────────────────────────────────────────────────────────
def menu_scan():
    try:
        if not os.path.exists(DISCOVER_PATH):
            banner("Scan Log Directories")
            sys.stdout.write(f"{RED}  codered-discover.py not found at:\n  {DISCOVER_PATH}{RESET}\n\n")
            input("  Press Enter to return...")
            return
        spec   = importlib.util.spec_from_file_location("codered_discover", DISCOVER_PATH)
        module = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(module)
        module.run_discovery()
        input(f"\n  Press {BOLD}Enter{RESET} to return to menu...")
    except KeyboardInterrupt:
        sys.stdout.write(f"\n{YELLOW}  Scan cancelled.{RESET}\n")

# ── 2. MODULE SETUP ───────────────────────────────────────────────────────────
def menu_setup():
    state      = load_state()
    enabled    = set(state["enabled"])
    keys       = list(MODULES.keys())
    cursor     = 0
    view_start = 0

    def render():
        nonlocal view_start
        vp = get_viewport(reserved=8)
        if cursor < view_start:             view_start = cursor
        elif cursor >= view_start + vp:     view_start = cursor - vp + 1
        view_end = min(view_start + vp, len(keys))

        banner("Module Setup")
        sys.stdout.write(f"  {DIM}↑↓ move · Space toggle · A all · N none · Enter save · Q back{RESET}\n\n")

        for i in range(view_start, view_end):
            mid   = keys[i]
            mod   = MODULES[mid]
            tick  = f"{GREEN}✔{RESET}" if mid in enabled else f"{RED}✖{RESET}"
            arrow = f"{CYAN}▶{RESET}" if i == cursor else " "
            hi    = BOLD if i == cursor else ""
            sys.stdout.write(f"  {arrow} [{tick}] {hi}{mod['label']}{RESET}\n")
            if i == cursor:
                sys.stdout.write(f"       {DIM}{mod['desc']}{RESET}\n")

        sys.stdout.write(f"\n  {DIM}──────────────────────────────────────{RESET}\n")
        sys.stdout.write(f"  {len(enabled)} module(s) enabled\n")
        sys.stdout.flush()

    render()
    while True:
        ch = getch()
        if   ch == "UP"   and cursor > 0:            cursor -= 1
        elif ch == "DOWN" and cursor < len(keys) - 1: cursor += 1
        elif ch == " ":
            mid = keys[cursor]
            if mid in enabled: enabled.discard(mid)
            else:              enabled.add(mid)
        elif ch.lower() == "a": enabled = set(keys)
        elif ch.lower() == "n": enabled = set()
        elif ch in ("\r", "\n"):
            state["enabled"] = list(enabled)
            save_state(state)
            sys.stdout.write(f"\n{CYAN}  Applying configuration...{RESET}\n")
            ok = apply_state(state)
            if ok:
                restart_agent()
                sys.stdout.write(f"\n{GREEN}  ✔ Module configuration saved.{RESET}\n")
            input(f"\n  Press {BOLD}Enter{RESET} to return to menu...")
            return
        elif ch.lower() == "q":
            return
        render()

