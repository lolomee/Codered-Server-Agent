# ── Admin check ───────────────────────────────────────────────────────────────
def is_admin() -> bool:
    try:
        if sys.platform == "win32":
            import ctypes
            return ctypes.windll.shell32.IsUserAnAdmin() != 0
        return os.geteuid() == 0
    except Exception:
        return False

# ── Terminal input ────────────────────────────────────────────────────────────
def getch():
    if sys.platform == "win32":
        import msvcrt
        ch = msvcrt.getwch()
        if ch in ('\x00', '\xe0'):
            ch2 = msvcrt.getwch()
            if ch2 == 'H': return "UP"
            if ch2 == 'P': return "DOWN"
            return ''
        return ch
    else:
        import tty, termios
        fd  = sys.stdin.fileno()
        old = termios.tcgetattr(fd)
        try:
            tty.setraw(fd)
            ch = sys.stdin.read(1)
            if ch == "\x1b":
                sys.stdin.read(1)
                arrow = sys.stdin.read(1)
                if arrow == "A": return "UP"
                if arrow == "B": return "DOWN"
                return ''
            return ch
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)

